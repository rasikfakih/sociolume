# ===========================================
# SOCIOLUME - Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your values
# DO NOT commit actual secrets to version control

# ------------------
# General
# ------------------
NODE_ENV=development

# ------------------
# Clerk Authentication
# ------------------
# Get these from your Clerk dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook Secret
# Get this from Clerk Dashboard > Webhooks > Your webhook > Secret
# This is required for the API gateway webhook handler
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# ------------------
# Supabase (Mumbai region - ap-south-1)
# ------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase Database URL (for server-side)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ------------------
# WordPress CMS (Headless)
# ------------------
NEXT_PUBLIC_WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_API_URL=https://your-wordpress-site.com/wp-json/wp/v2
WORDPRESS_API_KEY=your_wordpress_api_key

# ------------------
# HubSpot CRM
# ------------------
HUBSPOT_API_KEY=your_hubspot_api_key
HUBSPOT_PORTAL_ID=your_portal_id
HUBSPOT_WEBHOOK_SECRET=your_webhook_secret

# ------------------
# AI Service
# ------------------
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_API_KEY=your_ai_service_api_key

# ------------------
# API Gateway
# ------------------
API_PORT=3001
API_HOST=0.0.0.0

# ------------------
# Application
# ------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Sociolume
